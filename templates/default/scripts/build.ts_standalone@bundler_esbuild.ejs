import { copyFileSync, existsSync, mkdirSync, rmSync, writeFileSync } from 'node:fs';
import { builtinModules } from 'node:module';
import { join } from 'node:path';
import process from 'node:process';

import esbuild from 'esbuild';
<%- render('import') -%>

const prod = process.argv[2] !== 'dev';

if (prod) {
<%- render('compile') -%>
}

if (existsSync('.env')) {
  process.loadEnvFile('.env');
}

const distFolder = prod ? 'dist/build' : 'dist/dev';

if (existsSync(distFolder)) {
  rmSync(distFolder, { recursive: true });
}
mkdirSync(distFolder, { recursive: true });

copyFileSync('manifest.json', join(distFolder, 'manifest.json'));

<%- render('hot-reload') -%>

const banner = `/*
THIS IS A GENERATED/BUNDLED FILE BY ESBUILD
if you want to view the source, please visit the github repository of this plugin
*/
`;

const context = await esbuild.context({
  banner: {
    js: banner,
  },
  entryPoints: ['src/main.ts'],
  bundle: true,
  external: [
    'obsidian',
    'electron',
    '@codemirror/autocomplete',
    '@codemirror/collab',
    '@codemirror/commands',
    '@codemirror/language',
    '@codemirror/lint',
    '@codemirror/search',
    '@codemirror/state',
    '@codemirror/view',
    '@lezer/common',
    '@lezer/highlight',
    '@lezer/lr',
    'esbuild',
    'eslint',
    ...builtinModules,
  ],
  conditions: ['browser'],
  format: 'cjs',
  keepNames: true,
  logLevel: 'info',
  minify: prod,
  outfile: join(distFolder, 'main.js'),
  platform: 'node',
  sourcemap: prod ? false : 'inline',
  target: 'esnext',
  treeShaking: true,
<%- render('options') -%>
  plugins: [
<%- render('plugin') -%>
    copyToObsidianPluginsFolderPlugin(prod, distFolder),
  ],
});

if (prod) {
  await context.rebuild();
  process.exit(0);
} else {
  await context.watch();
}

function copyToObsidianPluginsFolderPlugin(isProduction: boolean, dist: string): esbuild.Plugin {
  return {
    name: 'copy-to-obsidian-plugins-folder',
    setup(build): void {
      build.onEnd(async () => {
        if (isProduction) {
          return;
        }

        const obsidianConfigFolder = process.env['OBSIDIAN_CONFIG_FOLDER'] ?? '';
        if (!obsidianConfigFolder) {
          return;
        }

        const pluginFolder = join(obsidianConfigFolder, 'plugins', '<%= pluginId %>');
        if (!existsSync(pluginFolder)) {
          mkdirSync(pluginFolder, { recursive: true });
        }

        const { cpSync } = await import('node:fs');
        cpSync(dist, pluginFolder, { recursive: true });
<%- render('reload', '        ') -%>
      });
    },
  };
}
