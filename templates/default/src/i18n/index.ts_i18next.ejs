import i18next from 'i18next';

import en from './locales/en.json';

export async function initI18n(): Promise<void> {
  await i18next.init({
    fallbackLng: 'en',
    lng: 'en',
    resources: {
      en: { translation: en }
    }
  });
}

export function t(key: string): string {
  return i18next.t(key);
}
