import assert from 'node:assert';
import test from 'node:test';

import { embedded } from 'obsidian-test';

embedded((app) => {
  test('<%= pluginName %> loads successfully', () => {
    assert.ok(app.workspace, 'Workspace should be available');
  });

  test('plugin is registered', () => {
    const pluginId = '<%= pluginId %>';
    const manifest = app.plugins.manifests[pluginId];
    assert.ok(manifest, `Plugin "${pluginId}" should have a manifest`);
    assert.strictEqual(manifest.id, pluginId);
  });

  test('sample command exists', () => {
    const commands = app.commands.listCommands();
    const sampleCommand = commands.find((cmd) => cmd.id === '<%= pluginId %>:sample');
    assert.ok(sampleCommand, 'Sample command should be registered');
  });
});
